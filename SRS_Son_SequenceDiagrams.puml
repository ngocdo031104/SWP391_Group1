@startuml
title UC-14: View Guide Dashboard

actor Guide
participant "GuideDashboardController" as Ctrl
participant "GuideDAO" as GDAO
participant "AttendanceDAO" as ADAO
participant "DB" as DB
participant "dashboard.jsp" as Dash
participant "participants.jsp" as Part

== Dashboard Main ==
Guide -> Ctrl: GET /guide/dashboard
Ctrl -> Ctrl: check session, role == "Guide"
alt not authorized
    Ctrl -> Guide: redirect /login or /home
end
Ctrl -> GDAO: getAssignmentsByGuideId(guideId)
GDAO -> DB: JOIN TourSchedule,Tour,TourStatus WHERE GuideID=?
DB --> GDAO: List<TourAssignment>
GDAO --> Ctrl: assignments
Ctrl -> Dash: forward /views/guide/dashboard.jsp
Dash --> Guide: Table: Tour, Destination, Departure, Status, Action buttons

== View Participants ==
Guide -> Dash: click "Danh sách đoàn"
Dash -> Ctrl: GET ?action=participants&scheduleId=X
Ctrl -> Ctrl: verify schedule is assigned to guide
alt not assigned
    Ctrl -> Dash: error msg → forward dashboard
end
Ctrl -> ADAO: getAttendanceByScheduleId(scheduleId)
ADAO -> DB: LEFT JOIN BookingParticipant + Attendance\nWHERE Booking.Status != 'Cancelled'
DB --> ADAO: participants with check-in data
ADAO --> Ctrl: participants
Ctrl -> Ctrl: calc checkedInCount, totalCount
Ctrl -> Part: forward /views/guide/participants.jsp
Part --> Guide: Progress bar X/Y, Table with check-in toggle
@enduml


@startuml
title UC-15: Manage Favorite Tours

actor Customer
participant "JS (TourCard)" as JS
participant "WishlistController" as Ctrl
participant "WishlistDAO" as DAO
participant "DB" as DB

Customer -> JS: click heart icon
JS -> Ctrl: AJAX POST /customer/wishlist/toggle?tourId=X
Ctrl -> Ctrl: check sessionUser != null
alt not logged in
    Ctrl -> JS: 401 {"status":"error"}
end

Ctrl -> DAO: toggleFavorite(userId, tourId)
DAO -> DB: SELECT COUNT(*) FROM FavoriteTour\nWHERE UserID=? AND TourID=?

alt already exists
    DAO -> DB: DELETE FROM FavoriteTour
    DAO --> Ctrl: "removed"
    Ctrl -> JS: {"status":"removed"}
    JS -> JS: heart icon → empty
else not exists
    DAO -> DB: INSERT INTO FavoriteTour
    DAO --> Ctrl: "added"
    Ctrl -> JS: {"status":"added"}
    JS -> JS: heart icon → filled
end
@enduml


@startuml
title UC-16: Submit Tour Review

actor Customer
participant "detail.jsp" as JSP
participant "DetailController" as Ctrl
participant "TourDAO" as DAO
participant "DB" as DB

Customer -> JSP: select stars (1-5), type content
JSP -> JSP: JS updates #review-rating-input

Customer -> JSP: click "Gửi Đánh Giá"
JSP -> Ctrl: POST /detail (tourId, rating, content)

Ctrl -> Ctrl: check sessionUser != null
alt not logged in
    Ctrl -> Customer: redirect /login
end

Ctrl -> Ctrl: name = sessionUser.getFullName()\nemail = sessionUser.getEmail()

Ctrl -> DAO: insertReview(name, email, tourId, rating, content)

DAO -> DB: Step 1: SELECT UserID FROM [User] WHERE Email=?
alt user not found
    DAO -> DB: INSERT [User] (role=4) + UserProfile
end

DAO -> DB: Step 3: SELECT BookingID\nJOIN Booking,TourSchedule\nWHERE CustomerID=? AND TourID=?
note right: KHÔNG check Status='Completed'
alt no booking
    DAO -> DB: fallback SELECT or INSERT dummy booking
end

DAO -> DB: INSERT INTO Review\n(TourID, BookingID, CustomerID, Rating, Content, IsVisible=1)
DB --> DAO: ok
DAO --> Ctrl: true

Ctrl -> Customer: redirect /detail?id={tourId}
JSP --> Customer: page reload, new review visible
@enduml


@startuml
title UC-28: Assign Tour Guide

actor "Admin/Staff" as Admin
participant "schedules-pricing.jsp" as JSP
participant "AdminSchedulePricingController" as Ctrl
participant "TourScheduleDAO" as SDAO
participant "GuideDAO" as GDAO
participant "DB" as DB

Admin -> JSP: select guide, fill schedule form, click Save
JSP -> Ctrl: POST /admin/schedules-pricing

alt action = addSchedule
    Ctrl -> SDAO: insertSchedule(sched)
    SDAO -> DB: INSERT INTO TourSchedule
    DB --> SDAO: newId
else action = updateSchedule
    Ctrl -> SDAO: updateSchedule(sched)
    SDAO -> DB: UPDATE TourSchedule
    Ctrl -> Ctrl: compare old GuideID vs new GuideID
end

alt guideId > 0 (or guide changed)
    Ctrl -> GDAO: assignGuideToSchedule(scheduleId, guideId, assignedBy, notes)
    GDAO -> DB: BEGIN TRANSACTION
    GDAO -> DB: Step 1: UPDATE TourSchedule SET GuideID=?
    GDAO -> DB: Step 2: INSERT INTO TourStatus (Status='Scheduled')
    GDAO -> DB: Step 3: MERGE INTO TourAssignment (upsert)
    alt success
        GDAO -> DB: COMMIT
        GDAO --> Ctrl: true
    else failure
        GDAO -> DB: ROLLBACK
        GDAO --> Ctrl: false
    end
end

Ctrl -> Admin: JSON {"status":"success"}
@enduml


@startuml
title UC-29: Check In Participants

actor Guide
participant "participants.jsp" as JSP
participant "GuideDashboardController" as Ctrl
participant "AttendanceDAO" as DAO
participant "DB" as DB

Guide -> JSP: click "Điểm danh" / "Hủy check-in"

JSP -> JSP: toggleCheckIn(participantId)\nread data-checked → toggle\nread notes from input

JSP -> Ctrl: AJAX POST /guide/dashboard\naction=checkin, scheduleId, participantId, checkedIn, notes

Ctrl -> Ctrl: check session, role=Guide
Ctrl -> Ctrl: verify guide is assigned to schedule
alt not assigned
    Ctrl -> JSP: 403 error
end

Ctrl -> DAO: saveAttendance(scheduleId, participantId, checkedIn, guideId, notes)

DAO -> DB: MERGE INTO Attendance\nON (ScheduleID, ParticipantID)\nWHEN MATCHED → UPDATE\nWHEN NOT MATCHED → INSERT

alt checkedIn=true
    DAO -> DAO: checkInTime = now()
else checkedIn=false
    DAO -> DAO: checkInTime = null
end

DB --> DAO: ok
DAO --> Ctrl: true

Ctrl -> JSP: JSON {status:"success", checkInTime:"HH:mm dd/MM"}

JSP -> JSP: updateProgress() — recount, update bar\nupdate status cell + button\nNO page reload
@enduml


@startuml
title UC-38: Export Revenue Reports

actor "Admin/Accountant" as User
participant "analytics.jsp" as JSP
participant "AdminAnalyticsController" as Ctrl
participant "AnalyticsDAO" as DAO
participant "DB" as DB

