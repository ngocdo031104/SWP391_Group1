@startuml
title UC-39: Perform Predictive Analytics

actor Admin
participant "forecast.jsp" as JSP
participant "AdminForecastController" as Ctrl
participant "AnalyticsDAO" as DAO
participant "DB" as DB

== Load History ==
Admin -> Ctrl: GET /admin/forecast
Ctrl -> Ctrl: check session, roleId==1
Ctrl -> DAO: getAllPredictions()
DAO -> DB: SELECT pr.*, u.FullName\nORDER BY GeneratedAt DESC
DB --> DAO: history
DAO --> Ctrl: predictionsHistory
Ctrl -> JSP: forward forecast.jsp
JSP --> Admin: chart area + type selector

== Run Forecast ==
Admin -> JSP: select type → AJAX GET ?action=getCalculations&type=Revenue

Ctrl -> DAO: calculateForecast(type)

group Revenue / BookingTrend
    DAO -> DB: getRevenueByMonth(6) or getBookingCountByMonth(6)
    DB --> DAO: 6 months historical
    DAO -> DAO: Linear Regression: slope, intercept\nR² → confidence (default 85% if all zero)\nPredict next 3 months
    DAO --> Ctrl: {historical, forecast, regression, confidence}
end

group Demand
    DAO -> DB: TOP 5 tours by bookings in 3 months
    DB --> DAO: topTours (fallback: random data if empty)
    DAO -> DAO: projectedBookings = round(avgPerMonth*1.15+2)\nconfidence = 88.5 (hardcoded)
    DAO --> Ctrl: {historical_top_tours, projected_demand, confidence:88.5}
end

Ctrl -> JSP: JSON forecast data
JSP --> Admin: Chart.js renders

== Save Snapshot ==
Admin -> JSP: click "Run Forecast" → POST
Ctrl -> Ctrl: extract confidence, inputData, resultData
Ctrl -> DAO: insertPrediction(pr)
DAO -> DB: INSERT INTO PredictionResult\n(ModelVersion="v1.0-Regression/WMA")
DB --> DAO: newId
DAO --> Ctrl: newId
Ctrl -> JSP: {"status":"success","newId":X}
@enduml


@startuml
title UC-42: Update Tour Status

actor Guide
participant "dashboard.jsp" as JSP
participant "GuideDashboardController" as Ctrl
participant "GuideDAO" as GDAO
participant "DB" as DB

Guide -> JSP: click "Trạng thái" button
JSP -> JSP: openStatusModal(scheduleId, currentStatus)\n- dropdown: Preparing|Scheduled|InProgress|Completed|Cancelled\n- textarea: notes

Guide -> JSP: select new status, enter notes, click "Xác nhận"

JSP -> Ctrl: AJAX POST /guide/dashboard\naction=updateStatus, scheduleId, newStatus, notes

Ctrl -> Ctrl: check session, role=Guide
Ctrl -> Ctrl: verify guide assigned to schedule
alt not assigned
    Ctrl -> JSP: 403
end
Ctrl -> Ctrl: validate newStatus ∈ {Preparing,Scheduled,InProgress,Completed,Cancelled}
alt invalid
    Ctrl -> JSP: 400
end

Ctrl -> GDAO: updateTourStatus(scheduleId, newStatus, notes, guideId)

GDAO -> DB: BEGIN TRANSACTION
GDAO -> DB: Step 1: UPDATE TourSchedule SET Status=newStatus
GDAO -> DB: Step 2: INSERT INTO TourStatus (history)
GDAO -> DB: Step 3: INSERT INTO TourOperationLog\n(Activity="HDV Cập nhật: "+newStatus)

alt success
    GDAO -> DB: COMMIT
    GDAO --> Ctrl: true
    Ctrl -> JSP: {"status":"success"}
    JSP -> JSP: alert → closeModal() → reload
else failure
    GDAO -> DB: ROLLBACK
    GDAO --> Ctrl: false
    Ctrl -> JSP: {"status":"error"}
end
@enduml


